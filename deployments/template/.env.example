# =============================================
#  Per-deployment configuration template
#  Copy to .env and fill in your own values.
# =============================================

# ---------- Discord ----------
DISCORD_TOKEN_SUPPORT=
GUILD_ID=
ADMIN_USER_ID=
MODERATOR_CHANNEL_ID=

# ---------- A. Translation ----------
TRANSLATE_PROVIDER=deepl              # deepl | claude
DEEPL_API_KEY=                        # required if provider=deepl
TRANSLATE_CHANNEL_IDS=                # comma-separated; empty = use only /translate on
TICKET_CATEGORY_IDS=                  # categories whose channels are auto-translated (e.g. tickets)
TRANSLATE_MIN_CONFIDENCE=0.85
TRANSLATE_DEFAULT_MODE=both           # both | en2ja | ja2en

# ---------- B. Intent suggestion ----------
COMMUNITY_CHANNEL_ID=                 # the chat channel to monitor (e.g. free-talk)
SUGGEST_MIN_CONFIDENCE=0.70
PRODUCT_INQUIRY_CHANNEL_ID=           # destination shown in advice text (e.g. #ticket)
SHIPPING_GUIDE_CHANNEL_ID=            # destination shown in advice text (e.g. #shipping-guide)
PRODUCT_ADVICE_TEXT=商品のお問い合わせは <#{PRODUCT_INQUIRY_CHANNEL_ID}> でチケットを開いてお聞きください🎫
SHIPPING_ADVICE_TEXT=送料は `/shipping` コマンドで概算が確認できます。詳しくは <#{SHIPPING_GUIDE_CHANNEL_ID}> をご覧ください📦
PRODUCT_ADVICE_TEXT_EN=For product inquiries, please open a ticket in <#{PRODUCT_INQUIRY_CHANNEL_ID}> 🎫
SHIPPING_ADVICE_TEXT_EN=You can estimate shipping with the `/shipping` command. See <#{SHIPPING_GUIDE_CHANNEL_ID}> for details 📦

# ---------- C. Shipping calculator ----------
SHIPPING_SHEET_ID=                    # Google Sheet ID
SHIPPING_SHEET_NAME=比較表US基準
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
PACKAGING_WEIGHT_G=1000
MAX_BOX_TOTAL_KG=20
MAX_SHEET_WEIGHT_KG=20

# ---------- D. Tickets ----------
TICKET_STAFF_ROLE_IDS=                # comma-separated; staff who can see ticket channels
TICKET_CATEGORY_ID=                   # category to host ticket channels
CARD_GAME_CHANNEL_ID=                 # referenced in /ticket panel ("place orders here")

# ---------- UI language overrides (optional) ----------
# Force English/Japanese regardless of user's Discord locale.
# FORCE_UI_LANG=en                    # global override
FORCE_UI_LANG_SHIPPING=en             # /shipping UI: always English
FORCE_UI_LANG_TICKET=en               # ticket welcome message: always English

# ---------- E. Welcome ----------
WELCOME_CHANNEL_ID=
WELCOME_AUTOROLE_IDS=                 # comma-separated; auto-assigned on join
WELCOME_RULES_CHANNEL_ID=
WELCOME_INTRO_CHANNEL_ID=
WELCOME_BANNER_URL=                   # large banner image (managed by /welcome setbanner)
WELCOME_THUMBNAIL_URL=                # override for top-right thumbnail (default: user avatar)
WELCOME_TITLE=                        # override embed title
WELCOME_COLOR=0x57F287                # embed border color (hex)
WELCOME_DESCRIPTION=                  # override description (placeholders: {user_mention}, {user_name}, {guild_name}, {member_count}, {rules}, {intro})

# ---------- Anthropic (intent / fallback translation) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
MONTHLY_BUDGET_USD=10
